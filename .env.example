# AWS Configuration
AWS_REGION=us-east-1
AWS_PROFILE=default

# Bedrock Model Configuration
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
BEDROCK_TEMPERATURE=0.0
BEDROCK_MAX_TOKENS=1024

# Agent Configuration
AGENT_MAX_TURNS=10

# Logging
LOG_LEVEL=INFO

# Database
POSTGRES_DSN=postgresql://agent:agent_dev_password@localhost:5432/banking
MONGODB_URI=mongodb://agent:agent_dev_password@localhost:27017/banking?authSource=admin
REDIS_URL=redis://:agent_dev_password@localhost:6379/0

# Cache TTLs
CACHE_TTL_ACCOUNT=30
CACHE_TTL_CUSTOMER=300

# Connection pool
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10